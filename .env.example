# ─── LLM API Keys ────────────────────────────────────────────────────────────
# Groq — FREE tier: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — FREE tier: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── RAG Settings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K_RETRIEVAL=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── OCR Settings ─────────────────────────────────────────────────────────────
OCR_BACKEND=paddleocr                # "paddleocr" (default) or "easyocr"
OCR_CONFIDENCE_THRESHOLD=0.75

# ─── ASR (faster-whisper) Settings ───────────────────────────────────────────
WHISPER_MODEL_SIZE=base              # tiny | base | small | medium | large
ASR_CONFIDENCE_THRESHOLD=0.70
FASTER_WHISPER_DEVICE=cpu            # cpu | cuda
FASTER_WHISPER_COMPUTE_TYPE=int8     # int8 (cpu) | float16 (cuda)

# ─── Agent Thresholds ─────────────────────────────────────────────────────────
VERIFIER_CONFIDENCE_THRESHOLD=0.80

# ─── FastAPI Settings ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Streamlit Settings ───────────────────────────────────────────────────────
# URL of the running FastAPI backend (change for cloud deployments)
# Local:  http://localhost:8000
# Docker: http://backend:8000
# Render: https://your-backend-app.onrender.com
API_BASE_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
